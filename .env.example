# Telegram
TELEGRAM_BOT_TOKEN=

# Database
DATABASE_URL=postgresql://piti:piti_secret@localhost:5432/piti
REDIS_URL=redis://localhost:6379

# LLM Providers
ANTHROPIC_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# OpenAI (for embeddings)
OPENAI_API_KEY=

# Docker
AGENT_IMAGE=piti-agent
AGENT_PORT_RANGE_START=4000
AGENT_PORT_RANGE_END=4100
# Container idle timeout before auto-destroy (default: 1 hour)
CONTAINER_IDLE_TIMEOUT_MS=3600000

# Defaults
DEFAULT_LLM_PROVIDER=claude
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
DEFAULT_LANGUAGE=english

# Access control - comma-separated Telegram user IDs (empty = open to everyone)
TELEGRAM_ALLOWED_USERS=
